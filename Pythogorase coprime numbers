def cop(i,j):
    return gcd(i,j)==1
def gcd(a,b):
    while(b!=0):
        rem=a%b
        a=b
        b=rem
    return a    

a=int(input("Enter any num: "))
for i in range(5,a):
    for j in range(4,i):
        for k in range(3,j):
            if (k*k+j*j==i*i and cop(i,j) and cop(i,k) and cop(j,k)):
                print(k,j,i)
